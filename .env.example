# =========================
# Frontend (Vite)
# =========================
# Deixe vazio para usar proxy local do Vite (/api -> http://localhost:3001)
VITE_API_URL=
VITE_APP_NAME=Syncro Event Desk

# =========================
# Backend (API)
# =========================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://[::1]:8080
JWT_SECRET=troque_este_jwt_secret_em_producao

# =========================
# MySQL
# =========================
# Opção 1: use variáveis separadas
DB_HOST=localhost
DB_PORT=3306
DB_NAME=event_calendar
DB_USER=app_user
DB_PASSWORD=app_password_secure_change_me
DB_CONNECTION_LIMIT=10

# Opção 2: use URL única (se definida, tem prioridade sobre DB_HOST/DB_PORT/...)
# DATABASE_URL=mysql://app_user:app_password_secure_change_me@127.0.0.1:3306/event_calendar

# =========================
# Usuário admin inicial
# =========================
ADMIN_EMAIL=admin@app.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador do Sistema

# =========================
# OAuth Google (opcional)
# =========================
# Frontend
VITE_GOOGLE_CLIENT_ID=

# Backend (login Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Backend (Google Calendar espelhado)
# Use uma conta de serviÃ§o com permissÃ£o no calendÃ¡rio alvo.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DELEGATED_USER_EMAIL=
GOOGLE_CALENDAR_SEND_UPDATES=all
GOOGLE_ALLOW_EVENT_WITHOUT_ATTENDEES_FALLBACK=false
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=America/Fortaleza
